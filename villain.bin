    std::cout << "   .stats - System stats" << std::endl;
    std::cout << "   .over - STOP EVERYTHING" << std::endl;
    std::cout << "   .stopfr - Stop FR" << std::endl;
    std::cout << "   .stopra - Stop RAID" << std::endl;
    std::cout << "   .stoprr - Stop RR" << std::endl;
    std::cout << "   .stopcs - Stop CS" << std::endl;
    std::cout << "   .session - Current session" << std::endl;
    std::cout << "   .sessions - All sessions" << std::endl;
    std::cout << "   .sudo id - Add sudo user" << std::endl;
    std::cout << "   .delsudo id - Remove sudo" << std::endl;
    std::cout << "   .sudolist - List sudo users" << std::endl;
    std::cout << "   .help - Show help" << std::endl;
    
    // Keep running
    std::string input;
    while (!shutdown_flag) {
        std::this_thread::sleep_for(std::chrono::seconds(1));
    }
    
    // Cleanup
    shutdown_flag = true;
    for (auto& [idx, queue] : queues) {
        queue.stop();
    }
    for (auto& [idx, worker] : workers) {
        if (worker.joinable()) worker.join();
    }
    
    curl_global_cleanup();
    std::cout << "👋 Shutdown complete!" << std::endl;
    return 0;
}
