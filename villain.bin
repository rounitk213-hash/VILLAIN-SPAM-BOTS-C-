}

// ==================== MAIN ====================
int main() {
    #ifdef __linux__
    curl_global_init(CURL_GLOBAL_ALL);
    #endif
    
    showBanner();
    loadConfig();
    
    if (SESSIONS.empty()) {
        std::cerr << "No sessions loaded! Add SESSION_0 in config.env" << std::endl;
        std::cerr << "Format: SESSION_0=string||owner_id" << std::endl;
        return 1;
    }
    
    // Initialize states and queues
    for (const auto& session : SESSIONS) {
        states[session.index] = BotState();
        workers[session.index] = std::thread(workerThread, session.index);
        active_sessions++;
        std::cout << "[✓] Session " << session.index << " initialized | Owner: " << session.owner << std::endl;
    }
    
    std::cout << "\n✅ " << active_sessions << " session(s) active!" << std::endl;
