    std::cout << "   .joinleft link - Leave channel" << std::endl;
    std::cout << "   .pg - Purge messages" << std::endl;
    std::cout << "   .dly 0.5 - Set speed" << std::endl;
    std::cout << "   .ping - Check latency" << std::endl;
    std::cout << "   .stats - System stats" << std::endl;
    std::cout << "   .over - STOP EVERYTHING" << std::endl;
    std::cout << "   .stopfr - Stop FR" << std::endl;
    std::cout << "   .stopra - Stop RAID" << std::endl;
    std::cout << "   .stoprr - Stop RR" << std::endl;
    std::cout << "   .stopcs - Stop CS" << std::endl;
    std::cout << "   .session - Current session" << std::endl;
    std::cout << "   .sessions - All sessions" << std::endl;
    std::cout << "   .sudo id - Add sudo user" << std::endl;
    std::cout << "   .help - Show help" << std::endl;
    
    std::cout << "\n💡 For demonstration, type numbers to test commands:" << std::endl;
    std::cout << "   1 - Start test raid" << std::endl;
    std::cout << "   2 - Stop raid" << std::endl;
    std::cout << "   3 - Show stats" << std::endl;
    std::cout << "   0 - Exit" << std::endl;
    
    // Interactive test mode
    std::string input;
    bool running = true;
    while (running && !shutdown_flag) {
        std::cout << "\n> ";
        std::getline(std::cin, input);
        
        if (input == "1" && !SESSIONS.empty()) {
            handleRaid(SESSIONS[0].index, -1001234567, 5390485406);
            std::cout << "Test raid started!" << std::endl;
        } else if (input == "2" && !SESSIONS.empty()) {
            stopAllOperations(SESSIONS[0].index);
        } else if (input == "3") {
            std::cout << "Uptime: " << getUptime() << std::endl;
            std::cout << "Active sessions: " << active_sessions << std::endl;
        } else if (input == "0" || input == "exit") {
            running = false;
        } else if (!input.empty() && input != "test") {
            std::cout << "Unknown command. Type 'help' for commands." << std::endl;
        }
    }
    
    // Cleanup
    shutdown_flag = true;
    for (auto& [idx, cv] : queue_cvs) {
        cv.notify_all();
    }
    for (auto& [idx, worker] : workers) {
        if (worker.joinable()) worker.join();
    }
    
    #ifdef __linux__
    curl_global_cleanup();
    #endif
    
    std::cout << "\n👋 Shutdown complete!" << std::endl;
    return 0;
}
